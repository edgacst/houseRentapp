generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PropertyType {
  OFFICETEL
  VILLA
  STORE
  APARTMENT
  STUDIO
}

enum RoomType {
  STUDIO
  TWO_ROOM
  THREE_ROOM
  OFFICETEL
  STORE
  OFFICE
}

enum RoomStatus {
  VACANT
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ContractStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  TERMINATED
}

enum RentStatus {
  PAID
  UNPAID
  LATE
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  properties   Property[]
  tenants      Tenant[]
  contracts    Contract[]
  rentPayments RentPayment[]
}

model Property {
  id        String       @id @default(uuid())
  userId    String
  name      String
  address   String
  type      PropertyType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms     Room[]
  contracts Contract[]

  @@index([userId])
}

model Room {
  id             String       @id @default(uuid())
  userId         String
  propertyId     String
  name           String
  floor          Int
  type           RoomType
  status         RoomStatus   @default(VACANT)
  deposit        Int          @default(0)
  monthlyRent    Int          @default(0)
  maintenanceFee Int          @default(0)
  area           Float        @default(0)
  memo           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts      Contract[]

  @@index([userId])
  @@index([propertyId])
}

model Tenant {
  id        String     @id @default(uuid())
  userId    String
  name      String
  phone     String
  email     String?
  memo      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@index([userId])
}

model Contract {
  id             String         @id @default(uuid())
  userId         String
  propertyId     String
  roomId         String
  tenantId       String
  startDate      DateTime
  endDate        DateTime
  deposit        Int
  monthlyRent    Int
  maintenanceFee Int
  paymentDay     Int
  status         ContractStatus @default(ACTIVE)
  memo           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room           Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rentPayments   RentPayment[]

  @@index([userId])
  @@index([propertyId])
  @@index([roomId])
  @@index([tenantId])
}

model RentPayment {
  id             String     @id @default(uuid())
  userId         String
  contractId     String
  dueDate        DateTime
  paidDate       DateTime?
  rentAmount     Int
  maintenanceFee Int
  status         RentStatus @default(UNPAID)
  memo           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract       Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contractId])
}
